@startuml
title RAG Flow — база политики командировок компании

start
partition "Оффлайн-индексация" {
  :Документы политики
  (PDF / Wiki / приказы);
  :Чанкинг
  (разбиение на фрагменты);
  :Эмбеддинг чанков
  (embedding model);
  :Индексация в Vector DB
  (+ метаданные: отдел, регион);
}
partition "Онлайн-запрос" {
  :Запрос агента/пользователя;
  :Гибридный поиск
  (dense + sparse / BM25);
  :Reranking
  (cross-encoder, top-k);
  :Prompt assembly
  (контекст политики + вопрос);
  :LLM -> ответ с опорой на политику;
}
stop
@enduml
